<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wealth Tax Quiz</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #e8e4dc;
    --bg-card: #f0ede6;
    --green-dark: #2d4a2d;
    --green-mid: #3d6b3d;
    --green-light: #5a8a5a;
    --green-pale: #8faf8f;
    --green-muted: #c5d5c5;
    --green-tint: #dce8dc;
    --accent: #4a7c4a;
    --text: #1a2e1a;
    --text-muted: #4a6040;
    --border: #b5c9b5;
    --correct: #2d6a2d;
    --correct-bg: #d4e8d4;
    --wrong: #7a2d2d;
    --wrong-bg: #f0d4d4;
    --wrong-border: #c87878;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Source Serif 4', Georgia, serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 40px 20px 80px;
  }

  .page-wrapper {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .header {
    border-top: 3px solid var(--green-dark);
    border-bottom: 1px solid var(--border);
    padding: 28px 0 22px;
    margin-bottom: 40px;
  }

  .header h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--green-dark);
    line-height: 1.25;
    margin-bottom: 12px;
  }

  .header p {
    font-size: 1rem;
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.6;
  }

  /* ── Quiz Section ── */
  .section-label {
    font-family: 'Playfair Display', serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green-light);
    margin-bottom: 16px;
  }

  .quiz-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 4px solid var(--green-mid);
    border-radius: 2px;
    padding: 28px 32px;
    margin-bottom: 20px;
    transition: border-left-color 0.3s;
  }

  .quiz-card.answered-correct { border-left-color: var(--correct); }
  .quiz-card.answered-wrong { border-left-color: var(--wrong-border); }

  .question-number {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green-pale);
    font-family: 'Playfair Display', serif;
    margin-bottom: 10px;
  }

  .question-text {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--green-dark);
    line-height: 1.55;
    margin-bottom: 20px;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .option-btn {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 2px;
    padding: 12px 16px;
    cursor: pointer;
    font-family: 'Source Serif 4', serif;
    font-size: 0.95rem;
    color: var(--text);
    text-align: left;
    transition: all 0.2s ease;
    line-height: 1.5;
  }

  .option-btn:hover:not(:disabled) {
    border-color: var(--green-mid);
    background: var(--green-tint);
    color: var(--green-dark);
  }

  .option-btn:disabled { cursor: default; }

  .option-btn.correct {
    border-color: var(--correct);
    background: var(--correct-bg);
    color: var(--correct);
    font-weight: 600;
  }

  .option-btn.wrong {
    border-color: var(--wrong-border);
    background: var(--wrong-bg);
    color: var(--wrong);
  }

  .option-letter {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--green-muted);
    color: var(--green-dark);
    font-size: 0.72rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    margin-top: 1px;
  }

  .option-btn.correct .option-letter { background: var(--correct); color: #fff; }
  .option-btn.wrong .option-letter { background: var(--wrong-border); color: #fff; }

  .feedback {
    margin-top: 14px;
    padding: 12px 16px;
    border-radius: 2px;
    font-size: 0.9rem;
    line-height: 1.6;
    display: none;
  }

  .feedback.show { display: block; }
  .feedback.correct { background: var(--correct-bg); color: var(--correct); border-left: 3px solid var(--correct); }
  .feedback.wrong { background: var(--wrong-bg); color: var(--wrong); border-left: 3px solid var(--wrong-border); }

  /* ── Score ── */
  .score-bar {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 20px 28px;
    margin: 28px 0 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .score-label {
    font-family: 'Playfair Display', serif;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .score-display {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--green-dark);
  }

  .score-track {
    flex: 1;
    min-width: 140px;
    height: 6px;
    background: var(--green-muted);
    border-radius: 3px;
    overflow: hidden;
  }

  .score-fill {
    height: 100%;
    background: var(--green-mid);
    border-radius: 3px;
    transition: width 0.5s ease;
    width: 0%;
  }

  .reset-btn {
    background: var(--green-dark);
    color: #fff;
    border: none;
    padding: 10px 22px;
    font-family: 'Playfair Display', serif;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s;
  }

  .reset-btn:hover { background: var(--green-mid); }

  /* ── Divider ── */
  .section-divider {
    border: none;
    border-top: 2px solid var(--border);
    margin: 8px 0 40px;
  }

  /* ── Bullet Points ── */
  .bullets-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--green-dark);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .bullets-section > p {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-style: italic;
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .bullets-intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 24px;
  }

  .bullet-group {
    margin-bottom: 28px;
    padding-left: 0;
  }

  .bullet-group-title {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--green-dark);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bullet-group-title .num-badge {
    background: var(--green-dark);
    color: #fff;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-family: 'Source Serif 4', serif;
    flex-shrink: 0;
  }

  .bullet-group p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 10px;
    padding-left: 32px;
  }

  .bullet-list {
    list-style: none;
    padding-left: 32px;
    margin-bottom: 10px;
  }

  .bullet-list li {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text);
    padding: 3px 0 3px 16px;
    position: relative;
  }

  .bullet-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 13px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green-pale);
  }

  .conclusion {
    background: var(--green-tint);
    border: 1px solid var(--green-muted);
    border-left: 4px solid var(--green-mid);
    border-radius: 2px;
    padding: 18px 22px;
    margin-top: 8px;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--green-dark);
  }

  @media (max-width: 600px) {
    .quiz-card { padding: 20px 18px; }
    .score-bar { flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>
<div class="page-wrapper">

  <!-- Header -->
  <div class="header">
    <h1>Why have countries been getting rid of wealth taxes?</h1>
    <p>Test your understanding, then review the key points below.</p>
  </div>

  <!-- Quiz -->
  <div class="section-label">Interactive Quiz</div>

  <div id="quiz-container"></div>

  <div class="score-bar">
    <div>
      <div class="score-label">Your score</div>
      <div class="score-display"><span id="score-num">0</span> / <span id="score-total">0</span></div>
    </div>
    <div class="score-track"><div class="score-fill" id="score-fill"></div></div>
    <button class="reset-btn" onclick="resetQuiz()">Reset Quiz</button>
  </div>

  <hr class="section-divider">

  <!-- Bullet Points Summary -->
  <div class="bullets-section">
    <div class="section-label">Summary</div>
    <h2>Why did countries move away from wealth taxes?</h2>
    <p>Key points from the explainer above</p>

    <p class="bullets-intro">In recent decades, many OECD countries have moved away from wealth taxes. These taxes were originally introduced to reduce wealth inequality and raise revenue from the richest households. However, over time governments found that wealth taxes often raised less revenue than expected and created economic and administrative challenges.</p>

    <div class="bullet-group">
      <div class="bullet-group-title"><span class="num-badge">1</span> Economic concerns</div>
      <p>Some economists argue that wealth taxes can affect investment and savings decisions. Because they tax the stock of wealth rather than income, they can:</p>
      <ul class="bullet-list">
        <li>Reduce incentives to save and invest</li>
        <li>Make it harder for business owners with illiquid assets to pay taxes</li>
        <li>Encourage capital flight, where wealthy individuals move assets to lower-tax countries</li>
      </ul>
      <p>As global financial markets became more integrated, governments became increasingly concerned about losing high-net-worth individuals and investment to other countries.</p>
    </div>

    <div class="bullet-group">
      <div class="bullet-group-title"><span class="num-badge">2</span> Administrative challenges</div>
      <p>Wealth taxes can also be difficult to implement in practice. Governments must estimate the value of many different types of assets, including:</p>
      <ul class="bullet-list">
        <li>Property</li>
        <li>Private businesses</li>
        <li>Financial investments</li>
        <li>Art or collectibles</li>
      </ul>
      <p>These valuations can be complex and change over time, creating opportunities for tax avoidance and increasing compliance costs. In many countries, the revenue collected was relatively small compared to the cost of administering the tax.</p>
    </div>

    <div class="bullet-group">
      <div class="bullet-group-title"><span class="num-badge">3</span> Political pressures</div>
      <p>Politics has also played a role. Wealth taxes are often strongly opposed by wealthy individuals and interest groups, who may have significant political influence. During the 1980s and 1990s, many countries also shifted toward lower taxation of capital and greater reliance on income and consumption taxes instead.</p>
    </div>

    <div class="conclusion">
      <strong>The result:</strong> Because of these economic concerns, administrative difficulties, and political pressures, many OECD countries chose to abolish their wealth taxes over the past few decades.
    </div>
  </div>

</div>

<script>
const questions = [
  {
    q: "What was the original purpose of wealth taxes when they were introduced?",
    options: [
      "To fund military spending",
      "To reduce wealth inequality and raise revenue from the richest households",
      "To replace income taxes entirely",
      "To encourage investment in public services"
    ],
    answer: 1,
    feedback: {
      correct: "Correct! Wealth taxes were designed to reduce inequality and generate revenue from wealthier households — but in practice they often fell short of these goals.",
      wrong: "Not quite. Wealth taxes were originally designed to reduce wealth inequality and raise revenue from the richest households."
    }
  },
  {
    q: "Why can wealth taxes be particularly problematic for business owners?",
    options: [
      "Businesses are always exempt from wealth taxes",
      "Business owners tend to be in lower income brackets",
      "They may hold significant wealth in illiquid assets, making it hard to pay a tax on the stock of wealth",
      "Wealth taxes only apply to financial assets, not businesses"
    ],
    answer: 2,
    feedback: {
      correct: "Correct! Business owners may hold their wealth in illiquid assets — assets that can't easily be sold — making it difficult to pay a tax based on total wealth.",
      wrong: "The key issue is illiquidity. Business owners may hold significant wealth in assets they can't easily sell, making it hard to pay a tax on the stock of wealth."
    }
  },
  {
    q: "What is 'capital flight' in the context of wealth taxes?",
    options: [
      "When governments invest capital overseas",
      "When wealthy individuals move their assets to lower-tax jurisdictions",
      "When businesses reduce their capital investment",
      "When stock markets fall due to tax increases"
    ],
    answer: 1,
    feedback: {
      correct: "Correct! Capital flight refers to wealthy individuals relocating themselves or their assets to lower-tax countries to avoid taxation.",
      wrong: "Capital flight is when wealthy individuals move their assets — or themselves — to lower-tax countries, reducing the tax base."
    }
  },
  {
    q: "Which of the following best describes a key administrative challenge of wealth taxes?",
    options: [
      "Too many people qualify as wealthy",
      "Valuing diverse assets is complex, costly, and creates avoidance opportunities",
      "Collecting the tax payments takes too long",
      "Wealthy individuals tend to refuse to file returns"
    ],
    answer: 1,
    feedback: {
      correct: "Correct! Assessing the value of property, businesses, art, and other assets is complex, changes over time, and creates significant opportunities for avoidance.",
      wrong: "The main issue is valuation: estimating the value of diverse, changing assets is complex, costly, and creates opportunities for tax avoidance."
    }
  },
  {
    q: "How did broader tax policy trends in the 1980s and 1990s affect wealth taxes?",
    options: [
      "Governments increased all forms of taxation to fund the welfare state",
      "A global shift toward higher capital taxes made wealth taxes redundant",
      "Many countries shifted toward lower capital taxation and greater reliance on income and consumption taxes",
      "International agreements banned wealth taxes across OECD countries"
    ],
    answer: 2,
    feedback: {
      correct: "Correct! The broader ideological and policy shift toward lower capital taxes in the 1980s and 1990s contributed to the decline of wealth taxes across many countries.",
      wrong: "During the 1980s and 1990s, many countries shifted toward lower taxation of capital and greater reliance on income and consumption taxes — which helped push wealth taxes out of favour."
    }
  },
  {
    q: "What does the evidence suggest about the revenue raised by wealth taxes relative to their cost?",
    options: [
      "They raised significantly more revenue than anticipated",
      "They were revenue-neutral — costs and income balanced out",
      "They often raised limited revenue relative to administrative costs — only a small share of GDP in most countries",
      "Revenue data was never collected systematically"
    ],
    answer: 2,
    feedback: {
      correct: "Correct! In most countries, wealth taxes raised a relatively small share of GDP, which made the high compliance and administrative costs hard to justify.",
      wrong: "Evidence shows that wealth taxes typically raised limited revenue — often a small percentage of GDP — making their high administrative costs hard to justify."
    }
  }
];

let answered = [];
let score = 0;

function buildQuiz() {
  const container = document.getElementById('quiz-container');
  container.innerHTML = '';
  answered = new Array(questions.length).fill(false);
  score = 0;
  updateScore();

  questions.forEach((q, qi) => {
    const card = document.createElement('div');
    card.className = 'quiz-card';
    card.id = `card-${qi}`;

    const letters = ['A','B','C','D'];
    const optionsHTML = q.options.map((opt, oi) => `
      <button class="option-btn" id="opt-${qi}-${oi}" onclick="selectAnswer(${qi}, ${oi})">
        <span class="option-letter">${letters[oi]}</span>
        <span>${opt}</span>
      </button>
    `).join('');

    card.innerHTML = `
      <div class="question-number">Question ${qi + 1} of ${questions.length}</div>
      <div class="question-text">${q.q}</div>
      <div class="options">${optionsHTML}</div>
      <div class="feedback" id="fb-${qi}"></div>
    `;
    container.appendChild(card);
  });

  document.getElementById('score-total').textContent = questions.length;
}

function selectAnswer(qi, oi) {
  if (answered[qi]) return;
  answered[qi] = true;

  const q = questions[qi];
  const card = document.getElementById(`card-${qi}`);
  const fb = document.getElementById(`fb-${qi}`);
  const isCorrect = oi === q.answer;

  // Disable all buttons for this question
  for (let i = 0; i < q.options.length; i++) {
    const btn = document.getElementById(`opt-${qi}-${i}`);
    btn.disabled = true;
    if (i === q.answer) btn.classList.add('correct');
    else if (i === oi && !isCorrect) btn.classList.add('wrong');
  }

  // Show feedback
  fb.className = `feedback show ${isCorrect ? 'correct' : 'wrong'}`;
  fb.innerHTML = `<strong>${isCorrect ? '✓ Correct' : '✗ Incorrect'}:</strong> ${isCorrect ? q.feedback.correct : q.feedback.wrong}`;

  card.classList.add(isCorrect ? 'answered-correct' : 'answered-wrong');

  if (isCorrect) score++;
  updateScore();
}

function updateScore() {
  const total = questions.length;
  const answeredCount = answered.filter(Boolean).length;
  document.getElementById('score-num').textContent = score;
  const pct = total > 0 ? (score / total) * 100 : 0;
  document.getElementById('score-fill').style.width = pct + '%';
}

function resetQuiz() {
  buildQuiz();
}

buildQuiz();
</script>
</body>
</html>
